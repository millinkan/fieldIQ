# ── FieldIQ Pro v3 — Environment Configuration ─────────────────────────────
# Copy to .env and configure before running ./deploy.sh

# ── API Authentication & Billing ───────────────────────────────────────────
DEFAULT_API_KEY=demo
API_KEYS=demo,analyst,enterprise
ENFORCE_API_KEY=false
ENFORCE_CREDITS=false
ENFORCE_RATE_LIMIT=false
RATE_LIMIT_PER_MINUTE=120

# ── Phase 2: Live API (free tiers) ─────────────────────────────────────────
LIVE_DATA_PROVIDER=mock        # mock | api_sports | sportmonks | footystats
API_SPORTS_KEY=
SPORTMONKS_KEY=

# ── Phase 3: Premium ───────────────────────────────────────────────────────
FOOTYSTATS_API_KEY=demo

# ── CORS ───────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost","http://localhost:80","http://localhost:3000"]

# ── Simulation & Cache ─────────────────────────────────────────────────────
MC_SIMULATIONS=10000
CACHE_TTL_SIMULATION=3600
RAPIDFUZZ_THRESHOLD=88

# ── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Logging ────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Development / Testing ──────────────────────────────────────────────────
# SKIP_MODEL_INIT=1          # skip PyTorch load (pytest / CI)
# MODEL_PATH=/app/data/models/match_mlp.pt
# SCALER_PATH=/app/data/models/scaler.joblib
